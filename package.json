{
  "name": "airbnb-clone",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w packages/shared && npm run build -w backend && npm run build -w frontend",
    "build:frontend": "npm run build -w frontend",
    "build:backend": "npm run build -w backend",
    "start:frontend": "npm run start -w frontend",
    "start:backend": "npm run start -w backend",
    "lint": "npm run lint -w frontend && npm run lint -w backend",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css}\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.5.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
